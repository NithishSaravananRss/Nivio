# TMDB API key used for search, home, detail, movies, and schedule requests.
TMDB_API_KEY=

# Optional TMDB v4 read access token for future TMDB endpoints that require bearer auth.
TMDB_READ_ACCESS_TOKEN=

# AniList GraphQL endpoint used by schedule/anime integrations.
ANILIST_API_URL=https://graphql.anilist.co

# Supabase project URL for upcoming desktop-backed data integrations.
SUPABASE_URL=

# Supabase anonymous public key for upcoming desktop-backed data integrations.
SUPABASE_ANON_KEY=

# Default IPTV M3U playlist URL shown by the Live TV public playlist action.
IPTV_PLAYLIST_URL=https://example.com/playlist.m3u

# Optional IPTV XMLTV/EPG endpoint for future Live TV guide integration.
IPTV_EPG_URL=

# Firebase web API key for future desktop auth/sync integration.
FIREBASE_WEB_API_KEY=

# Firebase project ID for future desktop auth/sync integration.
FIREBASE_PROJECT_ID=

# Firebase app ID for future desktop auth/sync integration.
FIREBASE_APP_ID=

# Firebase messaging sender ID for future notifications/cloud messaging.
FIREBASE_MESSAGING_SENDER_ID=

# Firebase storage bucket for future media/profile storage integration.
FIREBASE_STORAGE_BUCKET=

# Base URL for a future first-party backend API.
API_BASE_URL=

# Image/API proxy base URL used for TMDB API and image requests.
IMAGE_PROXY_URL=https://example.com

# Desktop logging level, for example: debug, info, warn, error.
LOG_LEVEL=info
